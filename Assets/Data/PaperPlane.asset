%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5c421a18b86054a498f9fd5484dbf660, type: 3}
  m_Name: PaperPlane
  m_EditorClassIdentifier: Assembly-CSharp::OrigamiModel
  modelName: Paper Plane
  paperWidth: 2.97
  paperHeight: 2.1
  subdivisionsX: 40
  subdivisionsY: 28
  paperThickness: 0.004
  frontMaterial: {fileID: 2100000, guid: b37fe92b9fc5b534dadfc57f89e1240a, type: 2}
  backMaterial: {fileID: 2100000, guid: 8c9039899b17c0f40916aeccb8559ae6, type: 2}
  steps:
  - instructionText: Start with a flat sheet of paper.
    foldLineStart: {x: 0, y: -1.05}
    foldLineEnd: {x: 0, y: 1.05}
    foldAngle: 0
    duration: 0.4
    regionMode: 0
    guideLine:
      visible: 1
      width: 0.02
    arrow:
      visible: 0
      arrowOrigin: {x: 0, y: 0}
      arrowDirection: {x: 0, y: 0}
    hasCameraOverride: 0
    cameraPosition: {x: 0, y: 0, z: 0}
    cameraRotation: {x: 0, y: 0, z: 0, w: 1}
  - instructionText: Fold the top-right corner down to the center line.
    foldLineStart: {x: 0, y: 1.05}
    foldLineEnd: {x: 1.485, y: 0}
    foldAngle: 180
    duration: 1
    regionMode: 4
    guideLine:
      visible: 1
      width: 0.02
    arrow:
      visible: 1
      arrowOrigin: {x: 1.1, y: 0.8}
      arrowDirection: {x: -0.7, y: -0.7}
    hasCameraOverride: 0
    cameraPosition: {x: 0, y: 0, z: 0}
    cameraRotation: {x: 0, y: 0, z: 0, w: 1}
  - instructionText: Fold the top-left corner down to the center line.
    foldLineStart: {x: 0, y: 1.05}
    foldLineEnd: {x: -1.485, y: 0}
    foldAngle: 180
    duration: 1
    regionMode: 5
    guideLine:
      visible: 1
      width: 0.02
    arrow:
      visible: 1
      arrowOrigin: {x: -1.1, y: 0.8}
      arrowDirection: {x: 0.7, y: -0.7}
    hasCameraOverride: 0
    cameraPosition: {x: 0, y: 0, z: 0}
    cameraRotation: {x: 0, y: 0, z: 0, w: 1}
  - instructionText: Fold the paper in half along the center crease.
    foldLineStart: {x: 0, y: -1.05}
    foldLineEnd: {x: 0, y: 1.05}
    foldAngle: 180
    duration: 1.2
    regionMode: 0
    guideLine:
      visible: 1
      width: 0.025
    arrow:
      visible: 1
      arrowOrigin: {x: 0.8, y: 0}
      arrowDirection: {x: -1, y: 0}
    hasCameraOverride: 0
    cameraPosition: {x: 0, y: 0, z: 0}
    cameraRotation: {x: 0, y: 0, z: 0, w: 1}
  - instructionText: Your paper plane is ready! Hold at the fold and throw gently.
    foldLineStart: {x: 0, y: -1.05}
    foldLineEnd: {x: 0, y: 1.05}
    foldAngle: 0
    duration: 0.4
    regionMode: 0
    guideLine:
      visible: 0
      width: 0.02
    arrow:
      visible: 0
      arrowOrigin: {x: 0, y: 0}
      arrowDirection: {x: 0, y: 0}
    hasCameraOverride: 0
    cameraPosition: {x: 0, y: 0, z: 0}
    cameraRotation: {x: 0, y: 0, z: 0, w: 1}
